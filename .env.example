# AI Infrastructure
AI_PROVIDER=google
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Market Data
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=

# Production Database (VPS Redis)
# Used for the app and local-to-vps maintenance scripts
