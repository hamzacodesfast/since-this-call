# Legacy REST API (Internal Docker use)
# Points to the local redis-proxy when containerized
KV_REST_API_URL=http://localhost:8080
KV_REST_API_TOKEN=example_token

# Production Domain
PRODUCTION_URL=https://sincethiscall.com
